<RDF xmlns="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:em="http://www.mozilla.org/2004/em-rdf#">

    <Description about="urn:mozilla:install-manifest">
        <em:id>{2a9dd520-4da7-11f1-b4ac-0800200c9a66}</em:id>
        <em:version>1.0</em:version>
        <em:build>195</em:build>
        <em:hash>c929aeb</em:hash>

        <!-- Target Application this theme can install into,
        with minimum and maximum supported versions. -->
        <em:targetApplication>
            <Description>
                <em:minVersion>140.0</em:minVersion>
                <em:maxVersion>140.*</em:maxVersion>
            </Description>
        </em:targetApplication>

        <!-- Front End MetaData -->
        <em:name>Namoroka</em:name>
        <em:description>A Firefox 1-3 theme for Nocturne.</em:description>
        <em:creator>travy-patty</em:creator>
        <em:homepageURL>https://github.com/echelon-theme/namoroka</em:homepageURL>

        <em:internalName>namoroka</em:internalName>
    </Description>

</RDF>